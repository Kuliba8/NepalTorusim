* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

/* FULL BACKGROUND IMAGE */
body {
    background: url('../bck.gif') no-repeat center center fixed;
    background-size: cover;
    color: white;
}

/* NAVBAR */
nav {
    background: rgba(0, 0, 0, 0.6);
    padding: 15px 0;
    text-align: center;
}

nav a {
    color: white;
    text-decoration: none;
    margin: 0 20px;
    font-weight: bold;
    transition: 0.3s;
}

nav a:hover {
    color: #f6b93b;
}

/* HERO SECTION */
.hero {
    height: 80vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.content {
    max-width: 800px;
}

.hero h1 {
    font-size: 50px;
}

.hero p {
    margin-top: 10px;
    font-size: 18px;
}

/* BUTTON */
.btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 20px;
    background: #f6b93b;
    color: black;
    text-decoration: none;
    border-radius: 5px;
    transition: 0.3s;
}

.btn:hover {
    background: #e58e26;
}

/* SECTION */
section {
    padding: 60px 20px;
    text-align: center;
}

/* SECTION TITLE */
section h2 {
    font-size: 32px;
    margin-bottom: 20px;
}

/* CARD CONTAINER */
.card-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 20px;
}

/* CARD STYLE */
.card {
    background: rgba(0, 0, 0, 0.6);
    padding: 20px;
    width: 250px;
    border-radius: 12px;
    transition: 0.3s;
    backdrop-filter: blur(5px);
}

/* CARD HOVER EFFECT */
.card:hover {
    transform: translateY(-8px);
    background: rgba(0, 0, 0, 0.75);
}

/* CARD TEXT */
.card h3 {
    margin-bottom: 10px;
    font-size: 20px;
}

.card p {
    font-size: 14px;
    line-height: 1.4;
}

/* FOOTER */
footer {
    background: rgba(0, 0, 0, 0.6);
    text-align: center;
    padding: 10px;
    margin-top: 20px;
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .hero h1 {
        font-size: 30px;
    }

    nav a {
        display: block;
        margin: 10px 0;
    }
}